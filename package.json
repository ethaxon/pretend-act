{
	"name": "pretend-act",
	"version": "0.1.0-alpha.1",
	"description": "A modern, programmatic local GitHub Actions toolkit built around nektos/act",
	"type": "module",
	"sideEffects": false,
	"files": [
		"dist",
		"README.md",
		"README_zh.md",
		"docs",
		"LICENSE.md",
		"CHANGELOG.md"
	],
	"exports": {
		".": {
			"dev": "./src/index.ts",
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.mts"
		},
		"./github": {
			"dev": "./src/github/index.ts",
			"import": "./dist/github/index.mjs",
			"types": "./dist/github/index.d.mts"
		},
		"./github-core": {
			"dev": "./src/github-core/index.ts",
			"import": "./dist/github-core/index.mjs",
			"types": "./dist/github-core/index.d.mts"
		},
		"./github-artifacts": {
			"dev": "./src/github-artifacts/index.ts",
			"import": "./dist/github-artifacts/index.mjs",
			"types": "./dist/github-artifacts/index.d.mts"
		},
		"./config": {
			"dev": "./src/config/index.ts",
			"import": "./dist/config/index.mjs",
			"types": "./dist/config/index.d.mts"
		},
		"./workflows": {
			"dev": "./src/workflows/index.ts",
			"import": "./dist/workflows/index.mjs",
			"types": "./dist/workflows/index.d.mts"
		},
		"./actions": {
			"dev": "./src/actions/index.ts",
			"import": "./dist/actions/index.mjs",
			"types": "./dist/actions/index.d.mts"
		},
		"./engine": {
			"dev": "./src/engine/index.ts",
			"import": "./dist/engine/index.mjs",
			"types": "./dist/engine/index.d.mts"
		},
		"./runner": {
			"dev": "./src/runner/index.ts",
			"import": "./dist/runner/index.mjs",
			"types": "./dist/runner/index.d.mts"
		},
		"./github-registry": {
			"dev": "./src/github-registry/index.ts",
			"import": "./dist/github-registry/index.mjs",
			"types": "./dist/github-registry/index.d.mts"
		},
		"./git-registry": {
			"dev": "./src/git-registry/index.ts",
			"import": "./dist/git-registry/index.mjs",
			"types": "./dist/git-registry/index.d.mts"
		},
		"./npm-registry": {
			"dev": "./src/npm-registry/index.ts",
			"import": "./dist/npm-registry/index.mjs",
			"types": "./dist/npm-registry/index.d.mts"
		},
		"./crates-registry": {
			"dev": "./src/crates-registry/index.ts",
			"import": "./dist/crates-registry/index.mjs",
			"types": "./dist/crates-registry/index.d.mts"
		},
		"./docker-registry": {
			"dev": "./src/docker-registry/index.ts",
			"import": "./dist/docker-registry/index.mjs",
			"types": "./dist/docker-registry/index.d.mts"
		},
		"./npm": {
			"dev": "./src/npm/index.ts",
			"import": "./dist/npm/index.mjs",
			"types": "./dist/npm/index.d.mts"
		},
		"./crates": {
			"dev": "./src/crates/index.ts",
			"import": "./dist/crates/index.mjs",
			"types": "./dist/crates/index.d.mts"
		}
	},
	"engines": {
		"node": ">=24.4.0"
	},
	"scripts": {
		"prepare": "prek install",
		"lint": "biome check",
		"lint-fix": "biome check --write",
		"typecheck": "tsc -b",
		"test": "vitest run",
		"test-watch": "vitest",
		"build": "tsdown",
		"dev": "tsdown --watch",
		"publish": "pnpm publish --access public"
	},
	"keywords": [
		"github-actions",
		"act",
		"testing",
		"mock",
		"github",
		"npm",
		"crates",
		"docker",
		"workflow"
	],
	"author": "Zhou Yeheng <root@aitiotekt.com>",
	"license": "MIT",
	"packageManager": "pnpm@10.33.0",
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@j178/prek": "^0.3.11",
		"@octokit/core": "^7.0.6",
		"@platformatic/vfs": "^0.4.0",
		"@redwoodjs/agent-ci": "^0.14.0",
		"dockerode": "^5.0.0",
		"@types/dockerode": "^4.0.1",
		"@types/node": "^25.6.0",
		"tsdown": "^0.21.10",
		"typescript": "^5.9.3",
		"verdaccio": "^6.2.1",
		"vitest": "^4.1.5"
	},
	"peerDependencies": {
		"@octokit/core": "^7.0.0",
		"@platformatic/vfs": "^0.4.0",
		"@redwoodjs/agent-ci": "^0.14.0",
		"dockerode": "^5.0.0",
		"verdaccio": "^6.0.0"
	},
	"peerDependenciesMeta": {
		"@octokit/core": {
			"optional": true
		},
		"@platformatic/vfs": {
			"optional": true
		},
		"@redwoodjs/agent-ci": {
			"optional": true
		},
		"dockerode": {
			"optional": true
		},
		"verdaccio": {
			"optional": true
		}
	},
	"overrides": {
		"typescript": "6.0.3"
	},
	"dependencies": {
		"injection-js": "^2.6.1",
		"isomorphic-git": "^1.37.6",
		"yaml": "^2.8.1"
	}
}
